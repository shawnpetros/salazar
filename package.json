  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/shawnpetros/salazar.git"
  },
  "homepage": "https://github.com/shawnpetros/salazar",
  "keywords": [
    "ai",
    "autonomous",
    "coding",
